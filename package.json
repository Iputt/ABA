{
  "name": "ABA",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "precommit": "eslint src/**/*.js",
    "plop": "plop",
    "doc": "vitepress dev docs --open",
    "bdoc": "vitepress build docs",
    "sdoc": "vitepress serve docs",
    "start": "gulp"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "prettier --write",
      "eslint --cache --fix",
      "git add"
    ]
  },
  "dependencies": {
    "ant-design-vue": "^2.1.2",
    "axios": "^0.21.0",
    "lodash": "^4.17.21",
    "vue": "^3.0.11",
    "vue-i18n": "^9.1.3",
    "vue-router": "^4.0.6",
    "vuex": "^4.0.0",
    "vxe-table": "^4.0.10",
    "xe-utils": "^3.0.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^2.33.0",
    "@typescript-eslint/parser": "^2.33.0",
    "@vue/cli-plugin-eslint": "~4.5.0",
    "@vue/cli-plugin-typescript": "~4.5.0",
    "@vue/cli-service": "~4.5.0",
    "@vue/compiler-sfc": "^3.0.11",
    "@vue/eslint-config-typescript": "^5.0.2",
    "autoprefixer": "^9.7.4",
    "babel-plugin-import": "^1.13.3",
    "browser-sync": "^2.26.14",
    "connect-history-api-fallback": "^1.6.0",
    "del": "^5.1.0",
    "dumber": "^1.14.7",
    "eslint": "^6.7.2",
    "eslint-plugin-vue": "^7.0.0-0",
    "gulp": "^4.0.2",
    "gulp-babel": "^8.0.0",
    "gulp-cache": "^1.1.3",
    "gulp-dumber": "^1.0.3",
    "gulp-if": "^3.0.0",
    "gulp-plumber": "^1.2.1",
    "gulp-tap": "^2.0.0",
    "gulp-terser": "^1.2.0",
    "gulp-vue-file": "^0.1.5",
    "husky": "^6.0.0",
    "plop": "^2.7.4",
    "postcss-url": "^8.0.0",
    "typescript": "~3.9.3",
    "vitepress": "^0.13.0"
  }
}
